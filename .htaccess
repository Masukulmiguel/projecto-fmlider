<IfModule mod_rewrite.c>
    RewriteEngine On

    # 1. Se for ficheiro real, deixa o Apache servir diretamente
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # 2. API routes -> root index.php (router proxies to backend)
    RewriteRule ^api/(.*)$ index.php?api=1&path=$1 [L,QSA]

    # 3. Frontend: serve os assets diretamente
    RewriteRule ^frontend/ - [L]

    # 4. Built assets: /assets/* -> frontend/dist/assets/*
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^assets/(.*)$ frontend/dist/assets/$1 [L]

    # 5. SPA fallback: tudo o resto vai para o index.html do dist
    RewriteRule ^ frontend/dist/index.html [L]
</IfModule>

<IfModule mod_headers.c>
    <Files "frontend/dist/index.html">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
    </Files>
</IfModule>

Options -Indexes
