# Backend environment variables
# Copy this file to .env and fill in the values

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=fmlider
DB_USERNAME=root
DB_PASSWORD=

# JWT
JWT_SECRET=your-random-secret-key-here

# Groq AI
GROQ_API_KEY=your-groq-api-key-here

# Admin credentials (used by DatabaseSeeder)
ADMIN_EMAIL=admin@fmlider.co.ao
ADMIN_PASSWORD=your-strong-password-here
ADMIN_PHONE=+244 935141747

# Secret reset key
SECRET_RESET_KEY=your-secret-reset-key-here
