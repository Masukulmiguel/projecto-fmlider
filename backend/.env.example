# Backend environment variables (example)
# Copy to .env and fill in real values

# MySQL (already configured in config/database.php)
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=fmlider
DB_USERNAME=root
DB_PASSWORD=

# JWT
JWT_SECRET=change-me-in-production

# Google Gemini AI - get key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
